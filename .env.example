# Merriam-Webster Collegiate Dictionary API key.
# Get one free at https://dictionaryapi.com/
# Add to Vercel project env vars (Production + Preview) when deploying.
MW_API_KEY=

# Resend API key for MW rate-limit alert emails.
# Sign up at https://resend.com/ — free tier (100 emails/day) is plenty.
# If missing, alerts are silently skipped.
RESEND_API_KEY=

# Where to send the MW rate-limit alert. Defaults to benjamincrystal8@gmail.com.
DEFINE_ALERT_TO=benjamincrystal8@gmail.com
